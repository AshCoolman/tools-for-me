#!/usr/bin/env bash
set -euo pipefail
umask 077

AH_DIR="$(cd "$(dirname "$0")/.." && pwd)"

case "${1:-}" in
  -h|--help)
    cat <<'USAGE'
tools/ah/scripts/start — run ah dev commands

Usage:
  ./tools/ah/scripts/start           interactive menu (TTY required)
  ./tools/ah/scripts/start build     build the ah binary
  ./tools/ah/scripts/start test      run tests
  ./tools/ah/scripts/start setup     verify mise + Go
  ./tools/ah/scripts/start install   build and install to ~/bin
USAGE
    exit 0
    ;;
esac

command -v mise >/dev/null 2>&1 || {
  printf 'FAIL: mise not found — install with: curl https://mise.run | sh\n' >&2
  exit 1
}

eval "$(mise activate bash 2>/dev/null)" || true
cd "$AH_DIR"
mise trust --yes >/dev/null 2>&1 || true
mise install --yes >/dev/null 2>&1

command -v go >/dev/null 2>&1 || {
  printf 'FAIL: go not on PATH after mise install — check .mise.toml\n' >&2
  exit 1
}

case "${1:-}" in
  setup)
    printf 'PASS: mise + go %s\n' "$(go version | awk '{print $3}')"
    ;;
  build)
    go build -o ah .
    printf 'PASS: built %s/ah\n' "$AH_DIR"
    ;;
  test)
    go test ./...
    ;;
  install)
    go build -o ah .
    mkdir -p "$HOME/bin"
    install -m 755 ah "$HOME/bin/ah"
    rm -f ah
    printf 'PASS: installed %s/bin/ah\n' "$HOME"
    ;;
  "")
    [ -t 0 ] || { printf 'FAIL: no command — requires TTY for menu\n' >&2; exit 1; }
    printf 'ah dev commands:\n'
    select cmd in build test setup install quit; do
      case "$cmd" in
        build)   go build -o ah . && printf 'PASS: built %s/ah\n' "$AH_DIR" ;;
        test)    go test ./... ;;
        setup)   printf 'PASS: mise + go %s\n' "$(go version | awk '{print $3}')" ;;
        install) go build -o ah . && mkdir -p "$HOME/bin" && install -m 755 ah "$HOME/bin/ah" && rm -f ah && printf 'PASS: installed %s/bin/ah\n' "$HOME" ;;
        quit)    exit 0 ;;
        *)       printf 'FAIL: invalid selection\n' >&2 ;;
      esac
      break
    done
    ;;
  *)
    printf 'FAIL: unknown command — %s\n' "$1" >&2
    exit 1
    ;;
esac
