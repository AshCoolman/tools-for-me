{
  "name": "@ashcoolman/claude-context-dashboard",
  "version": "0.1.0",
  "description": "Local dashboard for Claude Code sessions — per-session context fullness and token usage, scanned from ~/.claude/projects JSONL logs.",
  "license": "MIT",
  "author": "Ash Coolman <banquet.poll-4g@icloud.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AshCoolman/tools-for-me.git",
    "directory": "x/claude-context-dashboard"
  },
  "homepage": "https://github.com/AshCoolman/tools-for-me/tree/main/x/claude-context-dashboard",
  "bugs": "https://github.com/AshCoolman/tools-for-me/issues",
  "type": "module",
  "keywords": [
    "claude",
    "claude-code",
    "dashboard",
    "context-window",
    "tokens"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "nodemon --watch src --ignore 'src/client/**' --ext ts --delay 5 --exec 'tsx src/server.ts'",
    "build": "tsc -p tsconfig.server.json && vite build",
    "start": "NODE_ENV=production node dist/server.js",
    "prepublishOnly": "yarn build"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@fastify/static": "^8.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "d3-array": "^3.2.4",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "fast-glob": "^3.3.3",
    "fastify": "^5.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.19.2",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@types/d3-array": "^3.2.2",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-shape": "^3.1.8",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "nodemon": "^3.1.14",
    "typescript": "^5.7.2"
  },
  "color": "#112044"
}
