#!/usr/bin/env bash
set -euo pipefail

# Resolve symlinks so PKG_ROOT points at the real package, not e.g. a bin
# symlink under /opt/homebrew/bin/ created by `npm install -g .`.
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$SCRIPT_DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
PKG_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Env loading: package-shipped → user-global → project-local. Later wins.
load_env() {
  local f="$1"
  if [ -f "$f" ]; then
    set -a
    # shellcheck disable=SC1091
    . "$f"
    set +a
  fi
}

XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-${HOME}/.config}"
load_env "${PKG_ROOT}/.env"
load_env "${XDG_CONFIG_HOME}/token-smoulder/.env"
[ "${PWD}" != "${PKG_ROOT}" ] && load_env "${PWD}/.env"

# Prefer the locally-installed tsx (works for both `npm i -g .` installs and
# yarn-workspace dev), fall back to npx if missing.
LOCAL_TSX="${PKG_ROOT}/node_modules/.bin/tsx"
if [ -x "${LOCAL_TSX}" ]; then
  exec "${LOCAL_TSX}" "${PKG_ROOT}/src/cli/index.ts" "$@"
else
  exec npx --package=tsx@^4 --yes -- tsx "${PKG_ROOT}/src/cli/index.ts" "$@"
fi
