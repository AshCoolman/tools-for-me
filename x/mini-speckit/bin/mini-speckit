#!/usr/bin/env bash
set -eu

SOURCE="${BASH_SOURCE[0]}"
while [[ -h "$SOURCE" ]]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
PKG_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

cmd_help() {
  cat <<'EOH'
mini-speckit — lightweight spec lifecycle for single-doc deliverables

Usage:
  mini-speckit --help       Show this help
  mini-speckit --agents     Compact summary for AI agents
  mini-speckit install      Install host-native agent support into this repo
  mini-speckit uninstall    Remove host-native agent support from this repo
  mini-speckit status       Show install status for this repo

A specify -> plan -> tasks -> implement lifecycle that operates on a single
markdown file. Claude uses custom commands, Codex uses a project skill, and
Gemini uses a project skill plus native custom commands.

Typical repo setup:
  mini-speckit install

Installed surfaces:
  .claude/commands/mini-speckit-specify.md     Claude create-spec command
  .claude/commands/mini-speckit-next.md        Claude advance-spec command
  .claude/commands/spec-next-mini.md           Claude compatibility alias
  .codex/skills/mini-speckit/SKILL.md          Codex project skill
  .gemini/commands/mini-speckit/specify.toml   Gemini create-spec command
  .gemini/commands/mini-speckit/next.toml      Gemini advance-spec command
  .gemini/skills/mini-speckit/SKILL.md         Gemini project skill
EOH
}

cmd_agents() {
  cat <<'EOH'
mini-speckit: lightweight specify->plan->tasks->implement lifecycle for single-doc specs.
Claude entrypoints: /mini-speckit-specify to create a spec, /mini-speckit-next to advance it
Codex entrypoint: installed project skill at .codex/skills/mini-speckit
Gemini entrypoints: /mini-speckit:specify and /mini-speckit:next, plus the installed project skill
Repo setup: run mini-speckit install in the target repo
Specs live at: specs/<name>.md
Priority: checks NEXT.md at repo root for human-pinned priorities before scoring.
Not appropriate for: multi-task, cross-file impact, env vars, public surface contracts.
EOH
}

case "${1:---help}" in
  -h|--help)    cmd_help ;;
  --agents)     cmd_agents ;;
  install)      exec "$PKG_DIR/install.sh" install "${2:-all}" ;;
  uninstall)    exec "$PKG_DIR/install.sh" uninstall "${2:-all}" ;;
  status)       exec "$PKG_DIR/install.sh" status ;;
  *)
    echo "Unknown arg: $1" >&2
    echo "Run 'mini-speckit --help' for usage." >&2
    exit 2
    ;;
esac
