#!/usr/bin/env bash
set -eu

SOURCE="${BASH_SOURCE[0]}"
while [[ -h "$SOURCE" ]]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
PKG_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

cmd_help() {
  cat <<'EOH'
mini-speckit — lightweight spec lifecycle for single-doc deliverables

Usage:
  mini-speckit --help       Show this help
  mini-speckit --agents     Compact summary for AI agents
  mini-speckit install      Install Claude commands and Codex support into this repo
  mini-speckit uninstall    Remove Claude commands and Codex support from this repo
  mini-speckit status       Show install status for this repo

A specify -> plan -> tasks -> implement lifecycle that operates on a single
markdown file. Claude uses `/mini-speckit-specify` to create specs and
`/mini-speckit-next` to advance them; Codex uses the installed `mini-speckit`
skill registered in `AGENTS.md`.

Typical repo setup:
  mini-speckit install

Files:
  commands/mini-speckit-specify.md     Claude create-spec command
  commands/mini-speckit-next.md        Claude advance-spec command
  commands/spec-next-mini.md           Compatibility alias
  codex/skills/mini-speckit/SKILL.md   Codex skill definition
  template.md                          Single-file spec template reference
  HANDOFF.md                           NEXT.md contract for runners
EOH
}

cmd_agents() {
  cat <<'EOH'
mini-speckit: lightweight specify->plan->tasks->implement lifecycle for single-doc specs.
Claude entrypoints: /mini-speckit-specify to create a spec, /mini-speckit-next to advance it
Codex entrypoint: installed mini-speckit skill registered in AGENTS.md
Repo setup: run mini-speckit install in the target repo
Specs live at: specs/<name>.md
Hand-off: writes to NEXT.md at repo root; a separate runner ships the work.
Not appropriate for: multi-task, cross-file impact, env vars, public surface contracts.
EOH
}

case "${1:---help}" in
  -h|--help)    cmd_help ;;
  --agents)     cmd_agents ;;
  install)      exec "$PKG_DIR/install.sh" install "${2:-all}" ;;
  uninstall)    exec "$PKG_DIR/install.sh" uninstall "${2:-all}" ;;
  status)       exec "$PKG_DIR/install.sh" status ;;
  *)
    echo "Unknown arg: $1" >&2
    echo "Run 'mini-speckit --help' for usage." >&2
    exit 2
    ;;
esac
